{
  "name": "mello-block-extensions",
  "version": "2.1.10",
  "description": "MelloBase Block Extensions",
  "author": "Ashley Pickering",
  "license": "GPL-2.0-or-later",
  "scripts": {
    "build": "wp-scripts build --webpack-src-dir=src/blocks --output-path=build/blocks && webpack --config bin/webpack.extensions.config.js --env outputPath=build/extensions",
    "start": "npm run && wp-scripts start --webpack-src-dir=src/blocks --output-path=build/blocks && webpack --watch --config bin/webpack.extensions.config.js --env outputPath=build/extensions",
    "lint:css": "wp-scripts lint-style",
    "lint:js": "wp-scripts lint-js",
    "lint:js:src": "wp-scripts lint-js ./src",
    "lint:js:src:fix": "wp-scripts lint-js ./src --fix",
    "packages-update": "wp-scripts packages-update",
    "update-pot": "wp i18n make-pot . languages/mello-block-extensions.pot --exclude=src",
    "prepare": "wp-scripts build",
    "package": "node ./bin/package.js",
    "export": "npm run build && npm run package",
    "create-block": "cd ./src/blocks && npx @wordpress/create-block --namespace=mello-block --no-plugin",
    "create-block:dynamic": "cd ./src/blocks && npx @wordpress/create-block --namespace=mello-block --no-plugin --variant=dynamic",
    "version": "node ./bin/update-version.js && git add .",
    "preversion": "npm run build",
    "postversion": "npm run package",
    "release": "npm version patch && git push && git push --tags"
  },
  "dependencies": {
    "classnames": "^2.3.2",
    "lenis": "^1.2.3",
    "motion": "^12.7.3",
    "swiper": "^11.2.6"
  },
  "devDependencies": {
    "@wordpress/icons": "^9.35.0",
    "@wordpress/scripts": "^26.15.0",
    "glob": "^11.0.0",
    "micromodal": "^0.6.1",
    "mini-css-extract-plugin": "^2.9.2",
    "webpack-remove-empty-scripts": "^1.0.4"
  },
  "sideEffects": [
    "./src/blocks/swiper/variations.js",
    "./src/extensions/cover-ext-video/edit.js",
    "./src/extensions/**/*",
    "**/*.css",
    "**/*.scss"
  ]
}
