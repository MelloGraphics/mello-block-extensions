{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "mello-block/swiper",
  "version": "1.1.0",
  "title": "Swiper",
  "category": "design",
  "icon": "slides",
  "description": "Swiper block for content and query elements",
  "attributes": {
    "slidesPerViewXLarge": {
      "type": "number"
    },
    "slidesPerView": {
      "type": "number",
      "default": 3
    },
    "slidesPerViewTablet": {
      "type": "number",
      "default": 2
    },
    "slidesPerViewMobile": {
      "type": "number",
      "default": 1
    },
    "slidesPerViewAuto": {
      "type": "boolean",
      "default": false
    },
    "autoHeight": {
      "type": "boolean",
      "default": false
    },
    "spaceBetween": {
      "type": "number",
      "default": 75
    },
    "spaceBetweenXLarge": {
      "type": "number"
    },
    "spaceBetweenTablet": {
      "type": "number",
      "default": 50
    },
    "spaceBetweenMobile": {
      "type": "number",
      "default": 25
    },
    "loop": {
      "type": "boolean",
      "default": false
    },
    "loopAdditionalSlides": {
      "type": "number"
    },
    "direction": {
      "type": "string",
      "default": "horizontal"
    },
    "speed": {
      "type": "number",
      "default": 500
    },
    "centeredSlides": {
      "type": "boolean"
    },
    "freeMode": {
      "type": "boolean"
    },
    "freeModeMomentum": {
      "type": "boolean"
    },
    "freeModeMomentumRatio": {
      "type": "number",
      "default": 0.5
    },
    "freeModeMomentumVelocityRatio": {
      "type": "number",
      "default": 0.5
    },
    "freeModeSticky": {
      "type": "boolean"
    },
    "autoplay": {
      "type": "boolean"
    },
    "autoplayDelay": {
      "type": "number",
      "default": 3000
    },
    "autoplayDisableOnInteraction": {
      "type": "boolean"
    },
    "autoplayReverseDirection": {
      "type": "boolean"
    },
    "navigation": {
      "type": "boolean"
    },
    "navigationIcon": {
      "type": "boolean"
    },
    "pagination": {
      "type": "boolean"
    },
    "paginationClickable": {
      "type": "boolean"
    },
    "paginationType": {
      "type": "string"
    },
    "scrollbar": {
      "type": "boolean",
      "default": true
    },
    "scrollbarHide": {
      "type": "boolean"
    },
    "scrollbarDraggable": {
      "type": "boolean"
    },
    "allowTouchMove": {
      "type": "boolean"
    },
    "enableThumbs": {
      "type": "boolean"
    },
    "thumbsTarget": {
      "type": "string"
    },
    "effect": {
      "type": "string"
    },
    "mousewheel": {
      "type": "boolean"
    },
    "mousewheelForceToAxis": {
      "type": "boolean"
    },
    "mousewheelInvert": {
      "type": "boolean"
    },
    "mousewheelReleaseOnEdges": {
      "type": "boolean"
    },
    "mousewheelSensitivity": {
      "type": "number",
      "default": 1
    },
    "mousewheelEventsTarget": {
      "type": "string"
    },
    "a11y": {
      "type": "boolean"
    },
    "lazy": {
      "type": "boolean"
    },
    "loopFillGroupWithBlank": {
      "type": "boolean"
    },
    "simulateTouch": {
      "type": "boolean"
    },
    "touchRatio": {
      "type": "number"
    },
    "grabCursor": {
      "type": "boolean"
    },
    "slideToClickedSlide": {
      "type": "boolean"
    },
    "overflowHidden": {
      "type": "boolean"
    },
    "creativeEffectPrevTranslateX": {
      "type": "string",
      "default": "-100%"
    },
    "creativeEffectPrevTranslateY": {
      "type": "string",
      "default": "0"
    },
    "creativeEffectPrevTranslateZ": {
      "type": "number",
      "default": 0
    },
    "creativeEffectPrevOpacity": {
      "type": "number"
    },
    "creativeEffectPrevScale": {
      "type": "number"
    },
    "creativeEffectPrevRotateZ": {
      "type": "number"
    },
    "creativeEffectPrevShadow": {
      "type": "boolean"
    },
    "creativeEffectPrevOrigin": {
      "type": "string"
    },
    "creativeEffectNextTranslateX": {
      "type": "string",
      "default": "100%"
    },
    "creativeEffectNextTranslateY": {
      "type": "string",
      "default": "0"
    },
    "creativeEffectNextTranslateZ": {
      "type": "number",
      "default": 0
    },
    "creativeEffectNextOpacity": {
      "type": "number"
    },
    "creativeEffectNextScale": {
      "type": "number"
    },
    "creativeEffectNextRotateZ": {
      "type": "number"
    },
    "creativeEffectNextShadow": {
      "type": "boolean"
    },
    "creativeEffectNextOrigin": {
      "type": "string"
    },
    "creativeEffectLimitProgress": {
      "type": "number",
      "default": 1
    },
    "creativeEffectPrevFilter": {
      "type": "string"
    },
    "creativeEffectNextFilter": {
      "type": "string"
    }
  },
  "example": {},
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "spacing": {
      "margin": [
        "top",
        "bottom"
      ],
      "padding": true,
      "blockGap": true,
      "__experimentalDefaultControls": {
        "padding": true,
        "blockGap": true
      }
    },
    "color": {
      "background": true
    },
    "layout": {
      "allowSizingOnChildren": true
    },
    "dimensions": {
      "minHeight": true
    }
  },
  "textdomain": "swiper",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js"
}